# Pick OpenAI, Anthropic or Gemini for your AI model

# OpenAI API Configuration
# Get your API key from: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-your-key-here

# Anthropic API (for Claude models)
# Get your API key from: https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# Google AI API (for Gemini models)
# Get your API key from: https://makersuite.google.com/app/apikey
# GOOGLE_API_KEY=your-key-here

# Temporal Configuration (Optional - defaults to local dev server)
# TEMPORAL_HOST=localhost:7233
# TEMPORAL_NAMESPACE=default

# Temporal Cloud Configuration (Uncomment for cloud)
# TEMPORAL_HOST=namespace.abc12.tmprl.cloud:7233
# TEMPORAL_NAMESPACE=namespace.abc12

# System Configuration (Optional)
# LOG_LEVEL=INFO
# DOCS_CACHE_DIR=./cache
